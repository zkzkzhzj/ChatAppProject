# docker-compose 환경변수.
# 이 파일을 .env 로 복사한 뒤 환경에 맞게 수정한다.
#   cp .env.example .env

# ── 포트 ──
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# CASSANDRA_PORT=9042
# KAFKA_PORT=9092
# APP_PORT=8080
# FRONTEND_PORT=3000

# ── 프론트엔드 API 주소 (브라우저에서 접근하는 주소) ──
# 로컬: http://localhost:8080
# 서버: https://api.example.com
# PUBLIC_API_URL=http://localhost:8080
# PUBLIC_WS_URL=http://localhost:8080/ws

# ── NPC (AI 응답) ──
# hardcoded: 고정 문장 랜덤 반환 (기본값)
# ollama: Ollama LLM 응답 생성
# NPC_ADAPTER=hardcoded
# OLLAMA_PORT=11434
# OLLAMA_MODEL=qwen2.5:7b
