# docker-compose 환경변수.
# 이 파일을 .env 로 복사한 뒤 환경에 맞게 수정한다.
#   cp .env.example .env
# 주석 처리된 항목은 기본값이 있어 변경 불필요.

# ── Spring 프로필 ──
# local: 로컬 개발 (기본값)
# prod: 프로덕션 (EC2)
# SPRING_PROFILES_ACTIVE=local

# ── JWT (로컬은 기본값 있어 생략 가능, 프로덕션에서는 필수) ──
# JWT_SECRET=프로덕션에서는-반드시-변경

# ── NPC 어댑터 ──
# hardcoded: 고정 문장 랜덤 반환 (기본값, API 키 불필요)
# ollama: Ollama 로컬 LLM 응답 생성 (COMPOSE_PROFILES=ollama 도 같이 설정)
# openai: OpenAI API 응답 생성
# NPC_ADAPTER=hardcoded
# OPENAI_API_KEY=         # NPC_ADAPTER=openai 일 때 필수

# ── Docker Compose 프로필 ──
# ollama 컨테이너를 띄우려면 설정 (NPC_ADAPTER=ollama 일 때)
# COMPOSE_PROFILES=ollama

# ── DB (기본값: gohyang/gohyang) ──
# DB_USERNAME=gohyang
# DB_PASSWORD=gohyang

# ── 포트 (기본값 있음, 충돌 시 변경) ──
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# CASSANDRA_PORT=9042
# KAFKA_PORT=9092
# APP_PORT=8080
# FRONTEND_PORT=3000
# OLLAMA_PORT=11434

# ── Ollama 모델 (기본값: exaone3.5 + nomic-embed-text) ──
# OLLAMA_PULL_MODELS=exaone3.5:7.8b nomic-embed-text

# ── JVM 메모리 튜닝 (t3.medium 4GB 기준) ──
# 로컬 개발에서는 기본값으로 충분. EC2 4GB에서는 아래 값 권장.
# CASSANDRA_MAX_HEAP=512M
# CASSANDRA_HEAP_NEW=100M
# KAFKA_HEAP_OPTS=-Xmx256m -Xms128m
# JAVA_TOOL_OPTIONS=-Xmx256m -Xms128m

# ── CORS 허용 오리진 ──
# 프로덕션: EC2 퍼블릭 IP 또는 도메인으로 변경
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── 프론트엔드 API 주소 (기본값: localhost) ──
# 프로덕션: EC2 퍼블릭 IP 또는 도메인으로 변경
# PUBLIC_API_URL=http://localhost:8080
# PUBLIC_WS_URL=http://localhost:8080/ws

# ── CD 이미지 태그 (GHCR에서 pull할 이미지) ──
# GitHub Actions가 main push 시 자동으로 sha 태그를 심어 배포한다.
# EC2 .env 에는 deploy.sh가 매 배포마다 주입하므로 수동 설정 불필요.
# 로컬에서는 기본값 latest가 사용된다.
# APP_TAG=latest
# FRONTEND_TAG=latest
