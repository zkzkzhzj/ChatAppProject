# 환경변수 템플릿.
# 이 파일을 .env 로 복사 후 환경에 맞게 수정한다:
#   cp .env.example .env
#
# 모든 값은 backend의 application.yml 플레이스홀더(${ENV_VAR:default})와 매칭된다.
# 주석 처리된 항목은 로컬 기본값이 있어 로컬 개발엔 설정 불필요.

# ──────────────────────────────────────────
# 공통 — 포트 충돌 시에만 설정
# ──────────────────────────────────────────
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# CASSANDRA_PORT=9042
# KAFKA_PORT=9092
# APP_PORT=8080
# FRONTEND_PORT=3000
# OLLAMA_PORT=11434

# ──────────────────────────────────────────
# 시크릿 (운영에서는 반드시 설정)
# ──────────────────────────────────────────
# ⚠ 이 파일은 예제용. 값 복사해 쓰지 말 것. 운영에선 반드시 교체.
#
# 로컬: 아래 주석 해제 없이도 application.yml의 기본값으로 동작
# 운영: 아래 주석 해제 후 256비트 이상의 실제 값으로 교체
# JWT_SECRET=__REPLACE_WITH_256BIT_SECRET_IN_PRODUCTION__

# NPC_ADAPTER=openai 일 때만 필요 (빈 값이면 hardcoded NPC가 동작)
# OPENAI_API_KEY=__REPLACE_WITH_YOUR_KEY__

# ──────────────────────────────────────────
# DB / 인프라 자격증명
# ──────────────────────────────────────────
# 기본값 gohyang/gohyang. 운영에선 강한 비밀번호로 변경.
# DB_USERNAME=gohyang
# DB_PASSWORD=gohyang
# REDIS_PASSWORD=

# ──────────────────────────────────────────
# NPC 어댑터 선택
# ──────────────────────────────────────────
# hardcoded: 고정 문장 반환 (기본값, API 키 불필요)
# ollama:    로컬 Ollama (COMPOSE_PROFILES=ollama 같이 설정)
# openai:    OpenAI API (OPENAI_API_KEY 필수)
NPC_ADAPTER=hardcoded

# ollama 프로필 활성화 시:
# COMPOSE_PROFILES=ollama
# OLLAMA_PULL_MODELS=exaone3.5:7.8b nomic-embed-text

# ──────────────────────────────────────────
# 네트워크 / CORS
# ──────────────────────────────────────────
# 로컬: 기본값 localhost:3000,3001
# 운영: 실제 도메인으로 교체 (예: https://ghworld.co)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# 프론트엔드가 브라우저에서 직접 백엔드 호출하는 주소 (빌드 타임 주입)
# 운영: 퍼블릭 도메인
# PUBLIC_API_URL=http://localhost:8080
# PUBLIC_WS_URL=http://localhost:8080/ws

# ──────────────────────────────────────────
# 운영 보안 강화 (로컬 기본값은 개발 편의)
# ──────────────────────────────────────────
# compose 기본값이 'health'(가장 좁은 범위)라 secure by default.
# 운영에서 Prometheus scrape가 필요하면 아래를 해제해서 확장:
#
# ⚠ ACTUATOR_ENDPOINTS 와 SECURITY_ENV_PUBLIC_PATHS 는 반드시 함께 설정할 것.
#   엔드포인트만 열면 Spring Security가 인증을 요구해서 Prometheus가 scrape 실패함.
#   반대로 보안 경로만 풀면 엔드포인트가 존재하지 않아 404가 반환됨.
#
# ACTUATOR_ENDPOINTS=health,info,metrics,prometheus
# ACTUATOR_HEALTH_DETAILS=never
# HEALTH_REDIS_ENABLED=true
# SECURITY_COMMON_PUBLIC_PATHS=/api/v1/auth/register,/api/v1/auth/login,/api/v1/auth/guest,/ws/**
# SECURITY_ENV_PUBLIC_PATHS=/actuator/health,/actuator/prometheus

# ──────────────────────────────────────────
# 로깅
# ──────────────────────────────────────────
# 로컬: root=INFO, app=DEBUG (기본값)
# 운영: root=WARN, app=INFO 권장
# LOG_LEVEL_ROOT=INFO
# LOG_LEVEL_APP=DEBUG

# ──────────────────────────────────────────
# JVM 메모리 튜닝 (EC2 t3.medium 4GB 대응)
# ──────────────────────────────────────────
# 로컬 기본: -Xmx384m -Xms256m
# 운영(4GB 서버): 아래 값 권장
# CASSANDRA_MAX_HEAP=512M
# CASSANDRA_HEAP_NEW=100M
# KAFKA_HEAP_OPTS=-Xmx256m -Xms128m
# JAVA_TOOL_OPTIONS=-Xmx256m -Xms128m

# ──────────────────────────────────────────
# CD 이미지 태그 (deploy.sh가 주입, 수동 설정 불필요)
# ──────────────────────────────────────────
# APP_TAG=latest
# FRONTEND_TAG=latest
