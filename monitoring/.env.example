# gohyang-monitor EC2 (또는 로컬) 전용 환경변수.
# 실제 사용: cp .env.example .env → .env 수정 → docker compose up -d
# .env 파일은 git에 커밋하지 말 것 (.gitignore로 제외).

# ─────────────────────────────────────────────
# Grafana 관리자 비밀번호 (admin 계정)
# ─────────────────────────────────────────────
# 최소 12자 이상, 대소문자+숫자+특수문자 혼합 권장.
# docker-compose의 ${GRAFANA_ADMIN_PASSWORD:?required} 구문으로 강제 → 미설정 시 기동 실패.
GRAFANA_ADMIN_PASSWORD=change-this-to-strong-password

# ─────────────────────────────────────────────
# Scrape 대상 Private IP
# ─────────────────────────────────────────────
# Prometheus가 /actuator/prometheus 를 긁을 대상 서버의 Private IP.
# docker-compose의 extra_hosts 가 'gohyang-app' 호스트명을 이 IP로 매핑.
#
# AWS 환경 (모니터링 EC2):
#   운영 EC2(gohyang-server-ko)의 Private IPv4 주소
#   예) APP_PRIVATE_IP=172.31.45.140
#
# 로컬 테스트 (Docker Desktop Windows/Mac/Linux 공통):
#   APP_PRIVATE_IP=host-gateway
#   Docker 20.10+ 의 매직 키워드 — 런타임에 호스트 IP로 치환됨.
#   'host.docker.internal'은 DNS 이름이라 extra_hosts에 IP 자리로 못 쓴다.
APP_PRIVATE_IP=host-gateway
