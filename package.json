{
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:md": "markdownlint-cli2 \"docs/**/*.md\" \"*.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"docs/**/*.md\" \"*.md\""
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "markdownlint-cli2": "^0.22.0"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx,js,jsx}": [
      "npx --prefix frontend prettier --write --config frontend/.prettierrc",
      "npx --prefix frontend eslint --fix --config frontend/eslint.config.mjs"
    ],
    "frontend/src/**/*.{json,css}": [
      "npx --prefix frontend prettier --write --config frontend/.prettierrc"
    ],
    "backend/src/**/*.java": [
      "bash -c './backend/gradlew -p backend checkstyleMain checkstyleTest'"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ],
    "docs/**/*.md": [
      "markdownlint-cli2 --fix"
    ]
  }
}
